# Database
POSTGRES_DB=govtracker
POSTGRES_USER=govtracker
POSTGRES_PASSWORD=govtracker
DATABASE_URL=postgresql+asyncpg://govtracker:govtracker@postgres:5432/govtracker
DATABASE_URL_SYNC=postgresql+psycopg2://govtracker:govtracker@postgres:5432/govtracker

# Redis
REDIS_URL=redis://redis:6379/0

# GOV.UK
GOVUK_BASE_URL=https://www.gov.uk

# Parliament APIs
PARLIAMENT_MEMBERS_API_URL=https://members-api.parliament.uk/api
PARLIAMENT_BILLS_API_URL=https://bills-api.parliament.uk/api/v1
PARLIAMENT_QUESTIONS_API_URL=https://questions-statements-api.parliament.uk/api
PARLIAMENT_DIVISIONS_API_URL=https://commonsvotes-api.parliament.uk/data

# spaCy
SPACY_MODEL=en_core_web_sm

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Supabase Auth (backend JWT verification)
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Frontend
API_PROXY_TARGET=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
